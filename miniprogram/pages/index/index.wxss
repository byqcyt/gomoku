.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 10rpx;
}

.toolbar {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
  width: 100%;
  justify-content: center;
}

.picker {
  background: #fff;
  padding: 12rpx 24rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  border: 1rpx solid #ddd;
}

.btn {
  font-size: 26rpx;
  padding: 8rpx 20rpx;
  margin: 0;
  line-height: 1.5;
}

.board {
  width: 371px;
  height: 371px;
}

.status {
  margin-top: 16rpx;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.thinking {
  color: #999;
  font-size: 28rpx;
}
